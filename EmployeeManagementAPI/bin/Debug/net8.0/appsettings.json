    "Issuer": "EmployeeAPI",
    "Audience": "EmployeeAPI"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    //"DefaultConnection": "Server=KISSBSERVER\\MSSQLSERVER2019;Database=EmployeeDB;Trusted_Connection=True;User Id=sa; Password=sql@dmin7;TrustServerCertificate=True"
    "DefaultConnection": "Data Source=KISSBSERVER\\MSSQLSERVER2019; Initial Catalog=EmployeeDB; User Id=sa; Password=sql@dmin7;TrustServerCertificate=Yes  "

